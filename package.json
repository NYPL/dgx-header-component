{
  "name": "@nypl/dgx-header-component",
  "version": "2.6.0",
  "description": "NYPL Header as a React component.",
  "main": "dist/components/Header/Header.js",
  "scripts": {
    "start": "NODE_ENV=development node server.js",
    "babel-build": "./node_modules/.bin/babel src -d dist && cp -r src/styles/ dist/styles",
    "dist": "NODE_ENV=production ./node_modules/.bin/webpack --config webpack.config.js && cp -r src/styles/ dist/styles",
    "test": "IS_TEST_ENV=true ./node_modules/.bin/mocha test/helpers/browser.js test/*.test.js",
    "test-file": "IS_TEST_ENV=true node_modules/.bin/mocha -w test/helpers/browser.js",
    "test-with-coverage": "IS_TEST_ENV=true ./node_modules/.bin/nyc ./node_modules/.bin/mocha test/helpers/browser.js test/*.test.js",
    "coverage": "BABEL_ENV=test node_modules/.bin/nyc --require mocha npm test",
    "coverage-report": "BABEL_ENV=test node_modules/.bin/nyc report --reporter=lcov",
    "coverage-report-html": "BABEL_ENV=test ./node_modules/.bin/nyc report --reporter=html && open -a 'Google Chrome' ./coverage/index.html",
    "lint": "eslint ./",
    "lint-single-file": "eslint"
  },
  "author": "NYPL Digital Experience",
  "contributors": [
    {
      "name": "Edwin Guzman",
      "email": "edwinguzman@nypl.org"
    },
    {
      "name": "Rafael Hernandez",
      "email": "rafaelhernandez@nypl.org"
    },
    {
      "name": "Kang Peng",
      "email": "kangtingpeng@nypl.org"
    },
    {
      "name": "Sean Redmond",
      "email": "seanredmond@nypl.org"
    },
    {
      "name": "Ricardo E. Galvez",
      "email": "ricardogalvez@nypl.org"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NYPL/dgx-header-component.git"
  },
  "keywords": [
    "webpack",
    "react",
    "nypl"
  ],
  "dependencies": {
    "@nypl/design-toolkit": "0.1.36",
    "@nypl/dgx-svg-icons": "0.3.11",
    "axios": "0.19.2",
    "classnames": "2.2.6",
    "dgx-feature-flags": "git+https://git@github.com/NYPL/dgx-feature-flags.git#RENO-1288--package-updates",
    "dgx-react-ga": "git+https://git@github.com/NYPL/dgx-react-ga.git#RENO-1288--package-updates",
    "dgx-skip-navigation-link": "git+https://git@github.com/NYPL/dgx-skip-navigation-link.git#RENO-1288--package-updates",
    "focus-trap-react": "6.0.0",
    "moment": "2.25.3",
    "prop-types": "15.5.10",
    "react": "15.5.4",
    "react-dom": "15.5.4",
    "react-tappable": "1.0.0",
    "system-font-css": "2.0.2",
    "underscore": "1.10.2"
  },
  "devDependencies": {
    "axios-mock-adapter": "1.18.1",
    "@babel/cli": "7.8.4",
    "@babel/core": "7.9.6",
    "babel-eslint": "10.1.0",
    "babel-loader": "8.1.0",
    "babel-plugin-add-module-exports": "0.2.1",
    "babel-plugin-istanbul": "3.0.0",
    "@babel/preset-env": "7.9.6",
    "@babel/preset-react": "7.9.4",
    "@babel/register": "7.9.0",
    "chai": "3.5.0",
    "clean-webpack-plugin": "0.1.17",
    "create-react-class": "15.5.3",
    "css-loader": "0.28.7",
    "enzyme": "2.9.1",
    "eslint": "^5.9.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-loader": "1.3.0",
    "eslint-plugin-import": "^2.14.0",
    "eslint-plugin-jsx-a11y": "^6.1.2",
    "eslint-plugin-react": "^7.11.1",
    "extract-text-webpack-plugin": "2.1.2",
    "jsdom": "9.8.3",
    "mocha": "4.0.1",
    "node-sass": "4.14.1",
    "nyc": "15.0.1",
    "react-a11y": "0.3.3",
    "react-addons-test-utils": "15.5.0",
    "react-hot-loader": "1.2.8",
    "sass-loader": "5.0.0",
    "sinon": "4.0.1",
    "style-loader": "0.19.1",
    "webpack": "2.7.0",
    "webpack-dev-server": "2.7.1"
  }
